```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Dependencies
venv/
.venv/
.env
.env.local
*.env.*

# Build/dist directories
dist/
build/
target/

# Logs
*.log

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Coverage reports
coverage/
htmlcov/
.coverage

# OS files
.DS_Store
Thumbs.db

# Cache directories
.mypy_cache/
.pytest_cache/
.gradle/
```